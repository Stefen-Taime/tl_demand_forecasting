          "rawSql": "WITH bounds AS (SELECT MAX(target_hour) AS max_hour FROM zone_predictions) SELECT zp.zone_name, zp.borough, ROUND(AVG(zp.predicted_trips)::numeric, 1) AS avg_predicted, ROUND(AVG(zp.actual_trips)::numeric, 1) AS avg_actual, ROUND(AVG(zp.absolute_error)::numeric, 1) AS mae, COUNT(*) AS n_predictions, MAX(zp.model_version) AS model_version FROM zone_predictions zp CROSS JOIN bounds b WHERE zp.target_hour BETWEEN b.max_hour - INTERVAL '7 days' AND b.max_hour AND (${zone:sqlstring} = 'All' OR zp.zone_name = ${zone:sqlstring}) GROUP BY zp.zone_name, zp.borough ORDER BY mae ASC;",
