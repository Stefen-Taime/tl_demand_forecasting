          "format": "time_series",
          "rawQuery": true,
          "rawSql": "WITH bounds AS (SELECT MAX(target_hour) AS max_hour FROM zone_predictions) SELECT zp.target_hour AS time, SUM(zp.predicted_trips) AS predicted_trips, SUM(zp.actual_trips) AS actual_trips FROM zone_predictions zp CROSS JOIN bounds b WHERE zp.target_hour BETWEEN b.max_hour - INTERVAL '7 days' AND b.max_hour AND (${zone:sqlstring} = 'All' OR zp.zone_name = ${zone:sqlstring}) GROUP BY zp.target_hour ORDER BY zp.target_hour;",
