          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "WITH bounds AS (SELECT MAX(target_hour) AS max_hour FROM zone_predictions) SELECT zp.zone_name AS name, zp.latitude, zp.longitude, AVG(zp.predicted_trips) AS predicted, AVG(zp.actual_trips) AS actual, AVG(zp.absolute_error) AS error, zp.borough FROM zone_predictions zp CROSS JOIN bounds b WHERE zp.target_hour BETWEEN b.max_hour - INTERVAL '24 hours' AND b.max_hour AND (${zone:sqlstring} = 'All' OR zp.zone_name = ${zone:sqlstring}) AND zp.latitude IS NOT NULL AND zp.longitude IS NOT NULL GROUP BY zp.zone_name, zp.latitude, zp.longitude, zp.borough ORDER BY predicted DESC;",
